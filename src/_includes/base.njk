{% set current_lang = t.code or "es" %}
{% set common_t = i18n.commonByCode[current_lang] %}
<!DOCTYPE html>
<html lang="{{ current_lang }}">
<head>
    <script>
        (function() {
            const savedTheme = localStorage.getItem('darkMode');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'enabled' || (!savedTheme && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
            }
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recursos de Aprendizaje de Chino - PandaLatam</title>
    <link rel="icon" type="image/x-icon" href="/assets/PandaLatam.ico">
    <link rel="manifest" href="/manifest.json">


    
    <meta name="description" content="{{ description or 'Aprende chino gratis con ODL. Lecciones interactivas, gramática, vocabulario y comunidad para latinos.' }}">
    
    <!-- Preload LCP Image -->


    <!-- Lazy Load AdSense -->

    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome (Standard Loading to ensure icons appear) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" crossorigin="anonymous">
    
    <!-- Preserved Critical Styles -->
    <style>
        /* CRITICAL: Custom Scrollbars */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(156, 163, 175, 0.5); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(107, 114, 128, 0.8); }
        
        .dark-mode ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.2); }
        .dark-mode ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.4); }

        /* CRITICAL: Animations */
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes scaleIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        
        .animate-scaleIn { animation: scaleIn 0.3s ease-out forwards; }
        .animate-fadeIn { animation: fadeIn 0.3s ease-out forwards; }
        
        /* Utility for hiding scrollbars but allowing scroll */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* Mobile Carousel Fade Mask (Premium Feel) */
        .mask-fade-edges {
            -webkit-mask-image: linear-gradient(to right, transparent 0px, black 20px, black calc(100% - 20px), transparent 100%);
            mask-image: linear-gradient(to right, transparent 0px, black 20px, black calc(100% - 20px), transparent 100%);
        }

        /* Body Load Transition removed to fix flicker */
        body { opacity: 1; }

        /* Custom Background Pattern */
        .custom-bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image: url('/assets/ChinoLatamBac.png');
            background-repeat: repeat;
            background-position: center;
            background-size: 500px;
            opacity: 0.15;
            pointer-events: none;
            transition: all 0.3s ease;
        }
        .dark-mode .custom-bg-layer {
            opacity: 0.3;
            filter: invert(1);
        }
    </style>
    <!-- Mascot CSS -->
    <link rel="stylesheet" href="/css/mascot.css?v={{ timestamp }}">

    <link rel="stylesheet" href="/css/tailwind-output.css?v={{ timestamp }}">
    <!-- Inlined Content Styles (Professional & Clean) -->
    <style>
        {% include "css/critical-content.css" %}
    </style>

    {% if styles %}
    {% for style in styles %}
    <link rel="stylesheet" href="/css/{{ style }}?v={{ timestamp }}">
    {% endfor %}
    {% endif %}
    <script id="i18n-common" type="application/json">{{ common_t | dump | safe }}</script>
    <script>
        try {
            window.I18N_COMMON = JSON.parse(document.getElementById('i18n-common').textContent);
        } catch(e) {
            console.error('Error loading common i18n:', e);
            window.I18N_COMMON = {};
        }
    </script>
</head>
<body class="font-sans min-h-screen bg-white dark:bg-[#111] text-stone-800 dark:text-stone-100 transition-colors duration-300 selection:bg-red-500 selection:text-white">
    
    <!-- Fondo Personalizado (ChinoLatamBac) -->
    <div class="custom-bg-layer"></div>

    <!-- Main Container Global Wrapper -->
    <div class="max-w-7xl mx-auto md:px-4 md:py-8 min-h-screen flex flex-col relative z-10">
        <!-- White Card Container for EVERYTHING -->
        <div class="bg-transparent md:bg-white/95 dark:bg-stone-900 md:dark:bg-stone-900/95 md:backdrop-blur-md shadow-none md:shadow-2xl border-0 md:border md:border-white/20 dark:border-stone-700/50 overflow-hidden flex flex-col flex-grow">
            
            <!-- HEADER -->
            <header class="w-full bg-gradient-to-r from-red-600 to-orange-400 dark:from-stone-800 dark:to-stone-900 shadow-md dark:shadow-stone-900/40 relative z-20 transition-all duration-300 border-b border-transparent dark:border-stone-700/50">
                <!-- Optional Pattern Overlay for Dark Mode -->
                <!-- Optional Pattern Overlay for Dark Mode -->
                <div class="absolute inset-0 z-0 opacity-0 dark:opacity-20 bg-repeat pointer-events-none"></div>
                
                <div class="flex flex-col items-center justify-center p-3 md:p-6 md:min-h-[160px] relative z-10">
                    
                    <!-- ROW 1: TITLE -->
                    <div class="w-full flex justify-center items-center mb-1 md:mb-2 z-20">
                        <h1 class="text-white font-bold text-center text-lg md:text-5xl drop-shadow-md whitespace-nowrap">
                            Chino para Latinos
                        </h1>
                    </div>
    
                    <!-- ROW 2: NAV & LOGO -->
                    <div class="w-full flex justify-center items-center z-20 px-4 mt-2">
                        
                        <!-- BACKGROUND LOGO WATERMARK -->
                        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 opacity-15 dark:opacity-10 pointer-events-none z-0 overflow-hidden">
                            <img src="/assets/PandaLatamIC.png" alt="PandaLatam Logo" 
                                 class="h-28 md:h-40 lg:h-48 w-auto object-contain">
                        </div>
    
                        <!-- NAVIGATION TABS -->
                        <div class="flex flex-row md:flex-wrap overflow-x-auto md:overflow-visible w-full md:w-auto gap-2 md:gap-4 justify-start md:justify-center px-1 md:px-0 no-scrollbar relative z-10">
                            
                            <a href="{{ ('/' + t.dir) | replace('//', '/') }}" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/20 text-white text-xs md:text-lg font-semibold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg {% if page.url == '/' or page.url == '/en/' or page.url == '/tr/' %}bg-white/40 shadow-lg scale-105 border-white/40{% endif %}">
                                <i class="fas fa-home mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:scale-110 transition-transform"></i>
                                <span>{{ common_t.nav.home }}</span>
                            </a>
    
                            <a href="{{ ('/' + t.dir + 'Consejos/') | replace('//', '/') }}" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/20 text-white text-xs md:text-lg font-semibold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg {% if '/Consejos/' in page.url %}bg-white/40 shadow-lg scale-105 border-white/40{% endif %}">
                                <i class="fas fa-lightbulb mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:scale-110 transition-transform"></i>
                                <span>{{ common_t.nav.tips }}</span>
                            </a>
    
                            <a href="{{ ('/' + t.dir + 'Gramatica/') | replace('//', '/') }}" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-white/20 hover:bg-white/30 md:backdrop-blur-sm border border-white/20 text-white text-xs md:text-lg font-semibold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg {% if '/Gramatica/' in page.url %}bg-white/40 shadow-lg scale-105 border-white/40{% endif %}">
                                <i class="fas fa-book mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:scale-110 transition-transform"></i>
                                <span>{{ common_t.nav.grammar }}</span>
                            </a>
 
                            <a href="{{ ('/' + t.dir + 'Recursos/') | replace('//', '/') }}" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/20 text-white text-xs md:text-lg font-semibold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg {% if '/Recursos/' in page.url %}bg-white/40 shadow-lg scale-105 border-white/40{% endif %}">
                                <i class="fas fa-star mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:scale-110 transition-transform text-yellow-300"></i>
                                <span>{{ common_t.nav.resources }}</span>
                            </a>

                            <a href="{{ ('/' + t.dir + 'LabPanda/') | replace('//', '/') }}" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-gradient-to-r from-red-500/40 to-orange-500/40 hover:from-red-500/60 hover:to-orange-500/60 backdrop-blur-sm border border-white/30 text-white text-xs md:text-lg font-bold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg {% if '/LabPanda/' in page.url %}from-red-600/60 to-orange-600/60 shadow-lg scale-105 border-white/50{% endif %}">
                                <i class="fas fa-flask mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:rotate-12 transition-transform text-white"></i>
                                <span>LabPanda</span>
                            </a>
 
                            <button id="settingsTab" type="button" class="group inline-flex flex-col md:flex-row items-center justify-center px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/20 text-white text-xs md:text-lg font-semibold transition-all duration-300 whitespace-nowrap hover:-translate-y-1 hover:shadow-lg">
                                <i class="fas fa-cog mb-1 md:mb-0 md:mr-2 text-sm md:text-lg group-hover:scale-110 transition-transform"></i>
                                <span>{{ common_t.nav.settings }}</span>
                            </button>
                        </div>
                    </div>

                </div>
            </header>
            
            <!-- NOTICE BAR -->
            <!-- Dark Mode: Dark Red -->
            <div class="relative mx-4 mt-6 p-3 md:p-4 bg-yellow-400 dark:bg-stone-800 dark:border dark:border-stone-700/50 rounded-xl shadow-lg flex items-center justify-center gap-2 text-center text-sm md:text-base font-bold text-black dark:text-stone-200 transition-colors duration-300" id="noticeBar">
                <i class="fas fa-info-circle text-red-500 dark:text-red-400 text-lg"></i>
                <div class="flex items-center gap-2">
                    <a href="{{ ('/' + t.dir + 'register/') | replace('//', '/') }}" class="hover:text-stone-800 dark:hover:text-white underline decoration-2 decoration-black/30 dark:decoration-red-400/30 underline-offset-2 transition-colors">{{ common_t.nav.register }}</a>
                    <span class="opacity-50">/</span>
                    <span class="flex items-center gap-2">
                        <a href="{{ ('/' + t.dir + 'login/') | replace('//', '/') }}" class="hover:text-stone-800 dark:hover:text-white underline decoration-2 decoration-black/30 dark:decoration-red-400/30 underline-offset-2 transition-colors">{{ common_t.nav.login }}</a>
                    </span>
                </div>
            </div>
    
            <!-- MAIN CONTENT -->
            <main class="content flex-grow w-full relative z-10 px-4 md:px-8 py-6" id="mainContent">
                {{ content | safe }}
            </main>
    
            <!-- FOOTER -->
            <footer class="mt-auto py-8 bg-stone-50 dark:bg-stone-950 border-t border-stone-200 dark:border-stone-800 w-full">
                <div class="max-w-4xl mx-auto px-4 flex flex-col items-center justify-center text-center">
                    <div class="flex flex-wrap justify-center items-center gap-3 mb-4 text-sm font-medium text-stone-600 dark:text-stone-400">
                        <a href="{{ ('/' + t.dir + 'Dashboard/') | replace('//', '/') }}" class="hover:text-red-600 dark:hover:text-red-400 transition-colors">{{ common_t.footer.about }}</a>
                        <span class="text-stone-300 dark:text-stone-600">•</span>
                        <a href="{{ ('/' + t.dir + 'Contribuidores/') | replace('//', '/') }}" class="hover:text-red-600 dark:hover:text-red-400 transition-colors">{{ common_t.footer.contributors }}</a>
                        <span class="text-stone-300 dark:text-stone-600">•</span>
                        <a href="https://whydonate.com/fundraising/-apoya-mas-desarollos-para-nuestra-comunidad" target="_blank" class="hover:text-red-600 dark:hover:text-red-400 transition-colors">Apoyar</a>
                        <span class="text-stone-300 dark:text-stone-600">•</span>
                        <a href="{{ ('/' + t.dir + 'Privacy/') | replace('//', '/') }}" class="hover:text-red-600 dark:hover:text-red-400 transition-colors">{{ common_t.footer.privacy }}</a>
                    </div>
                    <p class="text-xs md:text-sm text-stone-500 dark:text-stone-500">
                        Hecho con <i class="fas fa-heart text-red-500 animate-pulse"></i> para la comunidad latina por ODL
                    </p>
                </div>
            </footer>
        </div>
    </div>

    <!-- SETTINGS PANEL OVERLAY -->
    <div id="settingsOverlay" class="fixed inset-0 bg-stone-900/60 backdrop-blur-sm z-[100] hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
        <div class="settings-panel w-full max-w-sm bg-white dark:bg-stone-800 rounded-3xl shadow-2xl border border-stone-200 dark:border-stone-700 transform scale-95 transition-transform duration-300">
            
            <div class="flex items-center justify-between p-5 border-b border-stone-100 dark:border-stone-700">
                <h2 class="text-xl font-bold text-stone-800 dark:text-white">{{ common_t.settings_panel.title }}</h2>
                <button id="closeSettingsBtn" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-stone-100 dark:hover:bg-stone-700 text-stone-500 dark:text-stone-400 transition-all hover:rotate-90">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
            
            <div class="p-5 space-y-4">
                <!-- Profile -->
                <div class="flex items-center gap-4 p-3 rounded-2xl bg-stone-50 dark:bg-stone-700/50">
                    <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-400">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="flex-grow">
                        <h3 class="font-semibold text-stone-800 dark:text-white text-sm">{{ common_t.settings_panel.profile_label }}</h3>
                        <p class="text-xs text-stone-500 dark:text-stone-400">{{ common_t.settings_panel.profile_desc }}</p>
                    </div>
                    <a href="/Perfil/" class="p-2 text-stone-400 hover:text-red-600 dark:hover:text-red-400 transition-colors">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>

                <!-- Dark Mode -->
                <div class="flex items-center justify-between p-3 rounded-2xl bg-stone-50 dark:bg-stone-700/50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400">
                            <i class="fas fa-moon"></i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-stone-800 dark:text-white text-sm">{{ common_t.settings_panel.dark_mode_label }}</h3>
                            <p class="text-xs text-stone-500 dark:text-stone-400">{{ common_t.settings_panel.dark_mode_desc }}</p>
                        </div>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="darkModeToggle" class="sr-only peer">
                        <div class="w-11 h-6 bg-stone-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-orange-300 dark:peer-focus:ring-orange-800 rounded-full peer dark:bg-stone-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-600"></div>
                    </label>
                </div>

                <!-- Panda AI Toggle -->
                <div class="flex items-center justify-between p-3 rounded-2xl bg-stone-50 dark:bg-stone-700/50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400">
                            <i class="fas fa-robot"></i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-stone-800 dark:text-white text-sm">{{ common_t.settings_panel.panda_ai_label }}</h3>
                            <p class="text-xs text-stone-500 dark:text-stone-400">{{ common_t.settings_panel.panda_ai_desc }}</p>
                        </div>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <!-- Default checked controlled by JS -->
                        <input type="checkbox" id="pandaToggle" class="sr-only peer">
                        <div class="w-11 h-6 bg-stone-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-orange-300 dark:peer-focus:ring-orange-800 rounded-full peer dark:bg-stone-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
                    </label>
                </div>

                <!-- Notifications -->
                <div class="flex items-center justify-between p-3 rounded-2xl bg-stone-50 dark:bg-stone-700/50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400">
                            <i class="fas fa-bell"></i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-stone-800 dark:text-white text-sm">{{ common_t.settings_panel.notifications_label }}</h3>
                            <p class="text-xs text-stone-500 dark:text-stone-400">{{ common_t.settings_panel.notifications_desc }}</p>
                        </div>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="notificationsToggle" checked class="sr-only peer">
                        <div class="w-11 h-6 bg-stone-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-amber-300 dark:peer-focus:ring-amber-800 rounded-full peer dark:bg-stone-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-amber-500"></div>
                    </label>
                </div>

                <!-- Language Toggle -->
                <div class="flex items-center justify-between p-3 rounded-2xl bg-stone-50 dark:bg-stone-700/50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
                            <i class="fas fa-language"></i>
                        </div>
                        <div>
                            <h3 class="font-semibold text-stone-800 dark:text-white text-sm">{{ common_t.settings_panel.language_label }}</h3>
                            <p class="text-xs text-stone-500 dark:text-stone-400">ES / EN / TR</p>
                        </div>
                    </div>
                    <select id="languageSelect" class="setting-select bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-600 rounded-lg px-2 py-1 text-sm font-medium text-stone-700 dark:text-stone-200 outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="tr">Türkçe</option>
                        <option value="es">Español</option>
                        <option value="en">English</option>
                    </select>
                </div>
            </div>
            
            <div class="p-5 border-t border-stone-100 dark:border-stone-700">
                <button id="resetSettingsBtn" class="w-full py-3 rounded-xl border border-stone-200 dark:border-stone-600 text-stone-600 dark:text-stone-300 font-medium hover:bg-stone-50 dark:hover:bg-stone-700 transition-colors text-sm">
                    {{ common_t.settings_panel.reset_btn }}
                </button>
            </div>
        </div>
    </div>
    
    <!-- Mascot Button (Static HTML for LCP) -->
    <div id="panda-btn" class="fixed bottom-6 right-6 z-[9990] cursor-pointer group transition-all duration-300 hover:scale-110 hidden">
        <div class="relative flex items-center justify-center w-[75px] h-[75px] md:w-[130px] md:h-[130px]">
             
             <!-- Mobile Backgrounds -->
             <div class="absolute inset-0 bg-gradient-to-tr from-red-500 via-orange-500 to-pink-500 opacity-20 dark:opacity-40 rounded-2xl md:hidden"></div>
             <div class="absolute inset-[2px] bg-white dark:bg-stone-800 rounded-xl md:hidden"></div>

             <!-- Desktop Speech Bubble -->
             <div class="absolute -top-12 right-0 bg-white dark:bg-stone-800 text-stone-800 dark:text-stone-200 text-sm py-1 px-3 rounded-lg shadow-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap border border-stone-200 dark:border-stone-700 hidden md:block">
                ¡Hola! Soy Panda
            </div>

            <!-- Image with Picture Tag -->
            <div class="relative z-10 w-full h-full flex items-center justify-center md:filter md:drop-shadow-xl md:hover:-translate-y-1 transition-transform p-[2px] md:p-0 bg-white dark:bg-stone-800 rounded-full shadow-lg border-2 border-orange-500">
                <span class="text-4xl md:text-6xl">🐼</span>
            </div>

            <!-- Desktop Ping -->
            <span class="absolute top-2 right-2 flex h-4 w-4 hidden md:flex">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-4 w-4 bg-orange-500"></span>
            </span>
        </div>
    </div>

    <!-- Panda Chat Window (Static HTML) -->
    <div id="panda-chat" class="capi-chat-modal transform translate-y-10 opacity-0 pointer-events-none hidden">
        <!-- Header -->
        <div class="flex items-center justify-between p-4 bg-gradient-to-r from-red-600 to-orange-600 md:rounded-t-2xl text-white shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 flex items-center justify-center -ml-2 text-2xl">
                    <!-- [TODO] Mascot Icon Placeholder -->
                    🐼
                </div>
                <div>
                    <h3 class="font-bold text-lg">Panda AI</h3>
                    <p class="text-xs text-red-100 flex items-center gap-1">
                        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                        En línea
                    </p>
                </div>
            </div>
            <!-- Expanded Actions -->
            <div class="flex items-center gap-1">
                    <button id="close-chat-btn" class="p-2 hover:bg-white/20 rounded-full transition-colors" title="Cerrar chat">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>

        <!-- Chat Container -->
        <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 bg-stone-50 dark:bg-stone-900/50 scroll-smooth">
            <!-- Welcome Message -->
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-900/50 flex items-center justify-center shrink-0 border border-red-200 dark:border-red-700 text-lg">
                    🐼
                </div>
                <div class="bg-white dark:bg-stone-800 p-3 rounded-2xl rounded-tl-none shadow-sm border border-stone-100 dark:border-stone-700 max-w-[85%]">
                    <p class="text-sm text-stone-600 dark:text-stone-300">
                        {{ common_t.footer.panda_welcome | safe }}
                    </p>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 bg-white dark:bg-stone-800 border-t border-stone-100 dark:border-stone-700 md:rounded-b-2xl">
            <form id="panda-form" class="relative flex items-end gap-2">
                <textarea 
                    id="chat-input" 
                    rows="1"
                    class="w-full bg-stone-50 dark:bg-stone-900 border-0 rounded-xl px-4 py-3 text-stone-700 dark:text-stone-200 focus:ring-2 focus:ring-red-500 resize-none max-h-32 text-sm shadow-inner"
                    placeholder="Escribe tu pregunta a Panda..."
                ></textarea>
                <button 
                    type="button"
                    id="send-msg-btn"
                    class="p-3 bg-red-600 hover:bg-red-700 text-white rounded-xl shadow-lg shadow-red-600/30 transition-all hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
                >
                    <svg class="w-5 h-5 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                </button>
            </form>
            <div class="text-center mt-2">
                <p class="text-[10px] text-stone-400 dark:text-stone-500">

                </p>
            </div>
        </div>
    </div>

